{
  "name": "aurora",
  "version": "1.0.0",
  "description": "Aurora — a real-time crypto portfolio tracker built with React Native + Expo. Reference-quality architecture: Expo Router, TanStack Query, Zustand, Reanimated 3, Skia.",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "jest --coverage"
  },
  "dependencies": {
    "@shopify/react-native-skia": "1.5.0",
    "@tanstack/react-query": "5.59.0",
    "expo": "~52.0.0",
    "expo-haptics": "~14.0.0",
    "expo-local-authentication": "~15.0.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "react": "18.3.1",
    "react-native": "0.76.3",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-mmkv": "3.1.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "zustand": "5.0.1"
  },
  "devDependencies": {
    "@testing-library/react-native": "12.8.0",
    "@types/jest": "29.5.13",
    "@types/react": "~18.3.12",
    "eslint": "9.13.0",
    "jest": "29.7.0",
    "jest-expo": "~52.0.0",
    "typescript": "5.6.3"
  },
  "private": true
}
